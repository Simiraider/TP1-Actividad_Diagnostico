---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { destinations } from '../../data/destinations.js';
import { GEMINI_API_KEY } from '../../data/config.js';

const slugify = (str) => str.toLowerCase().replace(/[^a-z0-9]+/g, '-');

export function getStaticPaths() {
  const slugify = (str) => str.toLowerCase().replace(/[^a-z0-9]+/g, '-');
  return destinations.map(dest => ({
    params: { slug: slugify(dest.title) },
    props: { dest },
  }));
}

const { dest } = Astro.props;
---

<Layout title={`RouteFlix - ${dest.title}`}>
  <Navbar />
  <main>
    <!-- Hero fullscreen -->
    <div class="hero-detail" style={`background-image: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7) 80%, var(--bg-color) 100%), url(${dest.image}); background-size: cover; background-position: center; height: 100vh; display: flex; align-items: center; justify-content: center; color: white; text-align: center;`}>
      <div>
        <h1 style="font-size: 3.5rem; margin-bottom: 1rem; text-shadow: 2px 2px 8px rgba(0,0,0,0.6);">{dest.title}</h1>
        <div style="font-size: 1.5rem; margin-bottom: 2rem; text-shadow: 1px 1px 4px rgba(0,0,0,0.5);">
          ⭐ {dest.rating} • {dest.price} • {dest.category}
        </div>
        <div style="font-size: 1.1rem; opacity: 0.8;">
          <i class="fa-solid fa-chevron-down" style="animation: bounce 2s infinite;"></i> Scroll para planificar tu viaje
        </div>
      </div>
    </div>

    <!-- Trip Planner Section -->
    <section class="trip-planner-section">
      <a href="/catalog" class="back-link">
        <i class="fa-solid fa-arrow-left"></i> Volver al catálogo
      </a>
      
      <h2>🗓️ Planificá tu viaje a {dest.title}</h2>
      <p class="section-subtitle">Completá los datos y nuestra IA generará un cronograma personalizado hora por hora</p>

      <form class="planner-form" id="planner-form">
        <div class="form-group">
          <label for="people-count"><i class="fa-solid fa-users"></i> Cantidad de personas</label>
          <input type="number" id="people-count" min="1" max="20" value="2" required>
        </div>

        <div class="form-group">
          <label for="age-group"><i class="fa-solid fa-cake-candles"></i> Grupo de edad</label>
          <select id="age-group" required>
            <option value="familia-mixta">👨‍👩‍👧‍👦 Familia mixta</option>
            <option value="jovenes" selected>🧑 Jóvenes (18-30)</option>
            <option value="adultos">🧑‍💼 Adultos (30-55)</option>
            <option value="adultos-mayores">👴 Adultos mayores (55+)</option>
            <option value="ninos">👶 Con niños</option>
          </select>
        </div>

        <div class="form-group">
          <label for="start-date"><i class="fa-regular fa-calendar-check"></i> Fecha de inicio</label>
          <input type="date" id="start-date" required>
        </div>

        <div class="form-group">
          <label for="budget"><i class="fa-solid fa-wallet"></i> Presupuesto</label>
          <select id="budget" required>
            <option value="bajo">Mochilero / Económico</option>
            <option value="medio" selected>Estándar / Medio</option>
            <option value="alto">Lujo / Alto</option>
          </select>
        </div>

        <div class="form-group">
          <label for="days-count"><i class="fa-solid fa-calendar-days"></i> Cantidad de días</label>
          <input type="number" id="days-count" min="1" max="14" value="3" required>
        </div>

        <button type="submit" class="generate-btn" id="generate-btn">
          <i class="fa-solid fa-wand-magic-sparkles"></i> Generar Cronograma
        </button>
      </form>

      <div class="error-message" id="error-message"></div>

      <div class="loading-container" id="loading">
        <div class="loading-spinner"></div>
        <p>Generando tu cronograma personalizado...</p>
      </div>

      <div class="itinerary-results" id="itinerary-results"></div>

      <div id="export-container" style="display: none; text-align: center; margin-top: 2rem;">
        <button id="export-btn" class="generate-btn" type="button" style="background: var(--primary-color);">
          <i class="fa-solid fa-calendar-plus"></i> Exportar a Google Calendar
        </button>
      </div>
    </section>
  </main>

  <style>
    @keyframes bounce {
      0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
      40% { transform: translateY(10px); }
      60% { transform: translateY(5px); }
    }
  </style>

  <script define:vars={{ destTitle: dest.title, destCategory: dest.category, apiKey: GEMINI_API_KEY }}>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('planner-form');
      const generateBtn = document.getElementById('generate-btn');
      const loading = document.getElementById('loading');
      const results = document.getElementById('itinerary-results');
      const errorMsg = document.getElementById('error-message');
      const exportContainer = document.getElementById('export-container');
      const exportBtn = document.getElementById('export-btn');

      let currentItinerary = null;
      let currentStartDate = null;

      const activityIcons = {
        'desayuno': '🍳', 'almuerzo': '🍽️', 'cena': '🍷', 'hotel': '🏨',
        'museo': '🏛️', 'playa': '🏖️', 'montaña': '🏔️', 'templo': '⛩️',
        'shopping': '🛍️', 'mercado': '🛒', 'cafe': '☕', 'bar': '🍸',
        'tour': '🚌', 'caminata': '🚶', 'foto': '📸', 'relax': '😌',
        'snorkel': '🤿', 'kayak': '🛶', 'bicicleta': '🚲', 'tren': '🚂',
        'avion': '✈️', 'taxi': '🚕', 'barco': '⛵', 'spa': '💆',
        'default': '📍'
      };

      function getIcon(activityName) {
        const name = activityName.toLowerCase();
        for (const [key, icon] of Object.entries(activityIcons)) {
          if (name.includes(key)) return icon;
        }
        return activityIcons['default'];
      }

      function showError(msg) {
        errorMsg.textContent = msg;
        errorMsg.classList.add('visible');
        setTimeout(() => errorMsg.classList.remove('visible'), 8000);
      }

      function renderItinerary(itinerary) {
        results.innerHTML = '';
        
        itinerary.days.forEach(day => {
          const dayCard = document.createElement('div');
          dayCard.classList.add('day-card');

          const header = document.createElement('div');
          header.classList.add('day-header');
          header.innerHTML = `
            <div class="day-number">${day.dayNumber}</div>
            <div class="day-title">${day.title}</div>
          `;
          dayCard.appendChild(header);

          const activitiesDiv = document.createElement('div');
          activitiesDiv.classList.add('day-activities');

          day.activities.forEach(act => {
            const row = document.createElement('div');
            row.classList.add('activity-row');
            row.innerHTML = `
              <span class="activity-time">${act.time}</span>
              <span class="activity-icon">${getIcon(act.name)}</span>
              <div class="activity-content">
                <div class="activity-name">${act.name}</div>
                <div class="activity-desc">${act.description}</div>
              </div>
            `;
            activitiesDiv.appendChild(row);
          });

          dayCard.appendChild(activitiesDiv);
          results.appendChild(dayCard);
        });

        results.classList.add('visible');
      }

      async function generateWithGemini(apiKey, people, ageGroup, days, budget) {
        const ageLabels = {
          'familia-mixta': 'familia con personas de distintas edades',
          'jovenes': 'jóvenes de 18 a 30 años',
          'adultos': 'adultos de 30 a 55 años',
          'adultos-mayores': 'adultos mayores de 55+ años',
          'ninos': 'familia con niños pequeños'
        };

        const prompt = `Generame un itinerario de viaje detallado para ${destTitle} (categoría: ${destCategory}).

Datos del viaje:
- ${people} personas
- Grupo: ${ageLabels[ageGroup] || ageGroup}
- ${days} días de estadía
- Presupuesto: ${budget}

Generame un cronograma hora por hora para cada día. Responde SOLO con JSON válido (sin markdown, sin backticks), con esta estructura exacta:
{
  "days": [
    {
      "dayNumber": 1,
      "title": "Título descriptivo del día",
      "activities": [
        {
          "time": "08:00",
          "name": "Nombre de la actividad",
          "description": "Descripción breve de la actividad, tips y recomendaciones"
        }
      ]
    }
  ]
}

Incluye actividades variadas: desayuno, visitas turísticas, almuerzo, actividades de la tarde, cena, etc. Adapta las actividades al grupo de edad. Incluye entre 6 y 10 actividades por día. Usa horarios realistas. Todo en español.`;

        const response = await fetch(
          `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent?key=${apiKey}`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contents: [{ parts: [{ text: prompt }] }],
              generationConfig: {
                temperature: 0.8,
                maxOutputTokens: 8192
              }
            })
          }
        );

        if (!response.ok) {
          const errData = await response.json().catch(() => ({}));
          throw new Error(errData?.error?.message || `Error de API: ${response.status}`);
        }

        const data = await response.json();
        const text = data.candidates?.[0]?.content?.parts?.[0]?.text;

        if (!text) throw new Error('La IA no generó una respuesta válida');

        // Clean up the response - remove markdown code blocks if present
        const cleanText = text.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();
        return JSON.parse(cleanText);
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const people = document.getElementById('people-count').value;
        const ageGroup = document.getElementById('age-group').value;
        const days = document.getElementById('days-count').value;
        const startDate = document.getElementById('start-date').value;
        const budget = document.getElementById('budget').value;

        if (days < 1 || days > 14) {
          showError('La cantidad de días debe ser entre 1 y 14.');
          return;
        }

        // Show loading
        errorMsg.classList.remove('visible');
        results.classList.remove('visible');
        results.innerHTML = '';
        exportContainer.style.display = 'none';
        loading.classList.add('visible');
        generateBtn.disabled = true;

        try {
          currentItinerary = await generateWithGemini(apiKey, people, ageGroup, days, budget);
          currentStartDate = startDate;

          loading.classList.remove('visible');
          renderItinerary(currentItinerary);
          exportContainer.style.display = 'block';
          
          // Scroll to results
          results.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (err) {
          loading.classList.remove('visible');
          showError('Error al generar el cronograma: ' + err.message);
          console.error('Gemini error:', err);
        } finally {
          generateBtn.disabled = false;
        }
      });

      exportBtn.addEventListener('click', () => {
        if (!currentItinerary || !currentStartDate) return;
        
        // Use T00:00:00 to avoid timezone offset issues when parsing date
        const baseDate = new Date(currentStartDate + 'T00:00:00');
        let icsContent = "BEGIN:VCALENDAR\nVERSION:2.0\nPRODID:-//RouteFlix//Itinerary//EN\n";
        
        currentItinerary.days.forEach((day, index) => {
          const eventDate = new Date(baseDate);
          eventDate.setDate(eventDate.getDate() + index);
          
          day.activities.forEach(act => {
            const timeMatch = act.time.match(/(\d{1,2}):(\d{2})/);
            let hours = 9, minutes = 0;
            if (timeMatch) {
              hours = parseInt(timeMatch[1], 10);
              minutes = parseInt(timeMatch[2], 10);
            }
            
            const startEvent = new Date(eventDate);
            startEvent.setHours(hours, minutes, 0);
            
            const endEvent = new Date(startEvent);
            endEvent.setHours(startEvent.getHours() + 1, minutes, 0);
            
            const formatForIcal = (date) => {
              return date.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
            };
            
            icsContent += "BEGIN:VEVENT\n";
            icsContent += `DTSTART:${formatForIcal(startEvent)}\n`;
            icsContent += `DTEND:${formatForIcal(endEvent)}\n`;
            icsContent += `SUMMARY:${act.name}\n`;
            icsContent += `DESCRIPTION:${act.description}\n`;
            icsContent += "END:VEVENT\n";
          });
        });
        
        icsContent += "END:VCALENDAR";
        
        const blob = new Blob([icsContent], { type: 'text/calendar;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `ruta-destino.ics`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      });

      // Navbar scroll
      const navbar = document.getElementById('navbar');
      if (navbar) {
        window.addEventListener('scroll', () => {
          navbar.classList.toggle('scrolled', window.scrollY > 50);
        });
      }
    });
  </script>
</Layout>
