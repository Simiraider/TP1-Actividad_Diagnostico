---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { destinations } from '../data/destinations.js';
import { GEMINI_API_KEY } from '../data/config.js';

const sortedDestinations = destinations.sort((a, b) => a.title.localeCompare(b.title));
---

<Layout title="RouteFlix - Armar Viaje Multidestino">
  <Navbar />
  <main class="page-container">
    <div class="header-banner">
      <h1>Armar Viaje Multidestino</h1>
      <p>Seleccioná varios destinos y nuestra IA generará el cronograma ideal para tu recorrido.</p>
    </div>

    <section class="trip-planner-section">
      <form class="planner-form" id="multi-planner-form">
        <div class="form-group form-full-width">
          <label><i class="fa-solid fa-map-location-dot"></i> Seleccionar Destinos (elegí 2 o más)</label>
          <input type="text" id="dest-search" placeholder="Buscar destino..." class="search-input">
          <div class="destinations-list" id="destinations-list">
            {sortedDestinations.map(dest => (
              <label class="dest-checkbox-label" data-title={dest.title.toLowerCase()}>
                <input type="checkbox" value={dest.title} name="selected-dests" class="dest-checkbox">
                {dest.title}
              </label>
            ))}
          </div>
        </div>

        <div class="form-grid">
          <div class="form-group">
            <label for="trip-title"><i class="fa-solid fa-pen"></i> Título del viaje</label>
            <input type="text" id="trip-title" placeholder="Ej: Eurotrip 2026" required>
          </div>

          <div class="form-group">
            <label for="people-count"><i class="fa-solid fa-users"></i> Cantidad de personas</label>
            <input type="number" id="people-count" min="1" max="20" value="2" required>
          </div>

          <div class="form-group">
            <label for="age-group"><i class="fa-solid fa-cake-candles"></i> Grupo de edad</label>
            <select id="age-group" required>
              <option value="familia-mixta">Familia mixta</option>
              <option value="jovenes" selected>Jóvenes (18-30)</option>
              <option value="adultos">Adultos (30-55)</option>
              <option value="adultos-mayores">Adultos mayores (55+)</option>
              <option value="ninos">Con niños</option>
            </select>
          </div>

          <div class="form-group">
            <label for="budget"><i class="fa-solid fa-wallet"></i> Presupuesto</label>
            <select id="budget" required>
              <option value="bajo">Mochilero / Económico</option>
              <option value="medio" selected>Estándar / Medio</option>
              <option value="alto">Lujo / Alto</option>
            </select>
          </div>

          <div class="form-group">
            <label for="start-date"><i class="fa-regular fa-calendar-check"></i> Fecha de inicio</label>
            <input type="date" id="start-date" required>
          </div>

          <div class="form-group">
            <label for="days-count"><i class="fa-solid fa-calendar-days"></i> Días totales</label>
            <input type="number" id="days-count" min="2" max="30" value="7" required>
          </div>
        </div>

        <button type="submit" class="generate-btn" id="generate-btn">
          <i class="fa-solid fa-wand-magic-sparkles"></i> Generar Itinerario Completo
        </button>
      </form>

      <div class="error-message" id="error-message"></div>

      <div class="loading-container" id="loading">
        <div class="loading-spinner"></div>
        <p>Conectando vuelos, buscando trenes y armando tu viaje ideal...</p>
      </div>

      <div id="results-container" style="display: none;">
        <div class="actions-bar">
          <button id="save-trip-btn" class="generate-btn save-btn">
            <i class="fa-solid fa-bookmark"></i> Guardar Viaje
          </button>
        </div>
        <div class="itinerary-results visible" id="itinerary-results"></div>
      </div>
    </section>
  </main>

  <style>
    .page-container {
      padding-top: 80px; /* Para que no lo tape el navbar */
      min-height: 100vh;
      background-color: var(--bg-color);
      color: white;
    }
    
    .header-banner {
      background: linear-gradient(to right, rgba(0,0,0,0.8), rgba(0,0,0,0.2)), url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=1200&q=80');
      background-size: cover;
      background-position: center;
      padding: 6rem 2rem;
      text-align: center;
    }

    .header-banner h1 {
      font-size: 3rem;
      margin-bottom: 1rem;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
    }
    
    .header-banner p {
      font-size: 1.2rem;
      text-shadow: 1px 1px 3px rgba(0,0,0,0.8);
      max-width: 600px;
      margin: 0 auto;
    }

    .trip-planner-section {
      max-width: 1000px;
      margin: -2rem auto 4rem auto;
      background: #181818;
      border-radius: 12px;
      padding: 2rem;
      position: relative;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    .form-full-width {
      width: 100%;
    }

    .search-input {
      width: 100%;
      padding: 12px;
      background: #333;
      border: 1px solid #444;
      color: white;
      border-radius: 6px;
      margin-bottom: 10px;
    }

    .destinations-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px;
      max-height: 250px;
      overflow-y: auto;
      background: #222;
      padding: 15px;
      border-radius: 6px;
      border: 1px solid #444;
    }

    .dest-checkbox-label {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.95rem;
      cursor: pointer;
      transition: color 0.2s;
    }

    .dest-checkbox-label:hover {
      color: var(--primary-color);
    }

    .destinations-list::-webkit-scrollbar {
      width: 8px;
    }
    .destinations-list::-webkit-scrollbar-track {
      background: #111; 
      border-radius: 4px;
    }
    .destinations-list::-webkit-scrollbar-thumb {
      background: #555; 
      border-radius: 4px;
    }
    .destinations-list::-webkit-scrollbar-thumb:hover {
      background: var(--primary-color); 
    }

    .actions-bar {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 2rem;
    }

    .save-btn {
      background: #28a745;
      width: auto;
      padding: 10px 20px;
      font-size: 1rem;
    }
    .save-btn:hover {
      background: #218838;
      transform: scale(1.05);
    }
  </style>

  <script define:vars={{ apiKey: GEMINI_API_KEY }}>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('multi-planner-form');
      const searchInput = document.getElementById('dest-search');
      const destLabels = document.querySelectorAll('.dest-checkbox-label');
      
      const generateBtn = document.getElementById('generate-btn');
      const loading = document.getElementById('loading');
      const resultsContainer = document.getElementById('results-container');
      const resultsDiv = document.getElementById('itinerary-results');
      const errorMsg = document.getElementById('error-message');
      
      const saveBtn = document.getElementById('save-trip-btn');

      let currentTripData = null;

      searchInput.addEventListener('input', (e) => {
        const val = e.target.value.toLowerCase();
        destLabels.forEach(label => {
          if(label.dataset.title.includes(val)) {
            label.style.display = 'flex';
          } else {
            label.style.display = 'none';
          }
        });
      });

      const activityIcons = {
        'desayuno': '🍳', 'almuerzo': '🍽️', 'cena': '🍷', 'hotel': '🏨',
        'museo': '🏛️', 'playa': '🏖️', 'montaña': '🏔️', 'templo': '⛩️',
        'shopping': '🛍️', 'mercado': '🛒', 'cafe': '☕', 'bar': '🍸',
        'tour': '🚌', 'caminata': '🚶', 'foto': '📸', 'relax': '😌',
        'vuelo': '✈️', 'tren': '🚂', 'bus': '🚌', 'traslado': '🚕',
        'llegada': '🛬', 'salida': '🛫',
        'default': '📍'
      };

      function getIcon(activityName) {
        const name = activityName.toLowerCase();
        for (const [key, icon] of Object.entries(activityIcons)) {
          if (name.includes(key)) return icon;
        }
        return activityIcons['default'];
      }

      function showError(msg) {
        errorMsg.textContent = msg;
        errorMsg.classList.add('visible');
        setTimeout(() => errorMsg.classList.remove('visible'), 8000);
      }

      function renderItinerary(itinerary) {
        resultsDiv.innerHTML = '';
        
        itinerary.days.forEach(day => {
          const dayCard = document.createElement('div');
          dayCard.classList.add('day-card');

          const header = document.createElement('div');
          header.classList.add('day-header');
          header.innerHTML = `
            <div class="day-number">${day.dayNumber}</div>
            <div class="day-title">${day.title}</div>
          `;
          dayCard.appendChild(header);

          const activitiesDiv = document.createElement('div');
          activitiesDiv.classList.add('day-activities');

          day.activities.forEach(act => {
            const row = document.createElement('div');
            row.classList.add('activity-row');
            row.innerHTML = `
              <span class="activity-time">${act.time}</span>
              <span class="activity-icon">${getIcon(act.name)}</span>
              <div class="activity-content">
                <div class="activity-name">${act.name}</div>
                <div class="activity-desc">${act.description}</div>
                ${act.locationUrl ? `<a href="${act.locationUrl}" target="_blank" class="activity-link"><i class="fa-solid fa-map-location-dot"></i> Ver en Mapa</a>` : ''}
              </div>
            `;
            activitiesDiv.appendChild(row);
          });

          dayCard.appendChild(activitiesDiv);
          resultsDiv.appendChild(dayCard);
        });

        resultsContainer.style.display = 'block';
      }

      async function generateWithGemini(apiKey, selectedDests, people, ageGroup, days, budget) {
        const ageLabels = {
          'familia-mixta': 'familia con personas de distintas edades',
          'jovenes': 'jóvenes de 18 a 30 años',
          'adultos': 'adultos de 30 a 55 años',
          'adultos-mayores': 'adultos mayores de 55+ años',
          'ninos': 'familia con niños pequeños'
        };

        const destListStr = selectedDests.join(" - ");

        const prompt = `Actúa como un experto agente de viajes. Planifica un viaje multidestino, que incluya los siguientes lugares: ${destListStr}.

Datos del viaje:
- ${people} personas
- Grupo: ${ageLabels[ageGroup] || ageGroup}
- Duración total: ${days} días
- Presupuesto: ${budget}

Distribuye lógicamente los días entre los destinos (por ejemplo, considera que cruzar países o ciudades lejanas toma tiempo, asigna días para vuelo/traslado). Generame un cronograma hora por hora para cada día.

Responde SOLO con JSON válido (sin markdown, sin backticks), con esta estructura exacta:
{
  "tripSummary": "Brevísima descripción del viaje y por qué la distribución de días es ideal",
  "days": [
    {
      "dayNumber": 1,
      "title": "Día 1: Llegada a [Destino] e inicio del viaje",
      "activities": [
        {
          "time": "10:00",
          "name": "Llegada y check-in",
          "description": "Llegada al primer destino, instalación en el alojamiento",
          "locationUrl": ""
        }
      ]
    }
  ]
}

Para cada actividad turística, el 'locationUrl' DEBE ser un link real de búsqueda de Google Maps siguiendo este formato: https://www.google.com/maps/search/?api=1&query=[nombre_del_lugar]+[nombre_de_la_ciudad].
Ej: "https://www.google.com/maps/search/?api=1&query=Coliseo+Roma". 

Incluye actividades variadas y tiempos de traslado inter-ciudades/países (vuelos o trenes figurativos). Todo en español.`;

        const response = await fetch(
          `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent?key=${apiKey}`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contents: [{ parts: [{ text: prompt }] }],
              generationConfig: {
                temperature: 0.8,
                maxOutputTokens: 8192
              }
            })
          }
        );

        if (!response.ok) {
          const errData = await response.json().catch(() => ({}));
          throw new Error(errData?.error?.message || `Error de API: ${response.status}`);
        }

        const data = await response.json();
        const text = data.candidates?.[0]?.content?.parts?.[0]?.text;

        if (!text) throw new Error('La IA no generó una respuesta válida');

        const cleanText = text.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();
        return JSON.parse(cleanText);
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const checkboxes = document.querySelectorAll('input[name="selected-dests"]:checked');
        if(checkboxes.length < 2) {
          showError("Por favor, selecciona al menos 2 destinos para armar un viaje multidestino.");
          return;
        }

        const selectedDests = Array.from(checkboxes).map(cb => cb.value);
        const tripTitle = document.getElementById('trip-title').value;
        const people = document.getElementById('people-count').value;
        const ageGroup = document.getElementById('age-group').value;
        const days = document.getElementById('days-count').value;
        const startDate = document.getElementById('start-date').value;
        const budget = document.getElementById('budget').value;

        if (days < 2 || days > 30) {
          showError('La cantidad total de días debe ser entre 2 y 30.');
          return;
        }

        errorMsg.classList.remove('visible');
        resultsContainer.style.display = 'none';
        loading.classList.add('visible');
        generateBtn.disabled = true;

        try {
          const itineraryData = await generateWithGemini(apiKey, selectedDests, people, ageGroup, days, budget);
          
          currentTripData = {
            id: Date.now().toString(),
            title: tripTitle,
            startDate: startDate,
            days: parseInt(days),
            destinations: selectedDests,
            itinerary: itineraryData,
            createdAt: new Date().toISOString()
          };

          loading.classList.remove('visible');
          renderItinerary(itineraryData);
          
          resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (err) {
          loading.classList.remove('visible');
          showError('Error al generar el cronograma: ' + err.message);
          console.error('Gemini error:', err);
        } finally {
          generateBtn.disabled = false;
        }
      });

      saveBtn.addEventListener('click', () => {
        if(!currentTripData) return;
        
        let savedTrips = [];
        try {
            const stored = localStorage.getItem('routeFlix_my_trips');
            if(stored) savedTrips = JSON.parse(stored);
        } catch(e) {}

        savedTrips.push(currentTripData);
        localStorage.setItem('routeFlix_my_trips', JSON.stringify(savedTrips));

        saveBtn.innerHTML = '<i class="fa-solid fa-check"></i> Viaje Guardado!';
        saveBtn.style.background = '#1a6f2b';
        saveBtn.disabled = true;

        setTimeout(() => {
            window.location.href = '/my-trips';
        }, 1500);
      });

      const navbar = document.getElementById('navbar');
      if (navbar) {
         navbar.classList.add('scrolled');
      }
    });
  </script>
</Layout>
