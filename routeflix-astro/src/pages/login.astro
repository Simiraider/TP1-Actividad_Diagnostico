---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RouteFlix - Iniciar sesión">
  <div class="auth-screen">
    <a href="/" class="auth-logo">RouteFlix</a>

    <div class="auth-card">
      <h1>Iniciar sesión</h1>

      <div id="auth-error" class="auth-error" style="display:none;"></div>
      <div id="auth-success" class="auth-success" style="display:none;"></div>

      <form id="login-form" autocomplete="on">
        <div class="form-group">
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="tu@email.com"
            required
            autocomplete="email"
          />
        </div>

        <div class="form-group">
          <label for="password">Contraseña</label>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="••••••••"
            required
            autocomplete="current-password"
          />
        </div>

        <button type="submit" id="login-btn" class="auth-btn">
          <span id="btn-text">Iniciar sesión</span>
          <span id="btn-spinner" class="spinner" style="display:none;"></span>
        </button>
      </form>

      <p class="auth-footer">
        ¿No tenés cuenta?
        <a href="/register">Registrate</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  import { signIn } from '../lib/auth.js';

  const form = document.getElementById('login-form');
  const errorBox = document.getElementById('auth-error');
  const successBox = document.getElementById('auth-success');
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorBox.style.display = 'none';
    successBox.style.display = 'none';
    btnText.style.display = 'none';
    btnSpinner.style.display = 'inline-block';

    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;

    try {
      await signIn(email, password);
      successBox.textContent = '¡Sesión iniciada! Redirigiendo...';
      successBox.style.display = 'block';
      setTimeout(() => { window.location.href = '/catalog'; }, 1000);
    } catch (err) {
      errorBox.textContent = err.message || 'Error al iniciar sesión. Revisá tus datos.';
      errorBox.style.display = 'block';
      btnText.style.display = 'inline';
      btnSpinner.style.display = 'none';
    }
  });
</script>

<style>
  .auth-screen {
    min-height: 100vh;
    background: #141414;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
  }

  .auth-logo {
    position: absolute;
    top: 2rem;
    left: 2rem;
    font-size: 2rem;
    font-weight: 900;
    color: #e50914;
    text-decoration: none;
    letter-spacing: -1px;
  }

  .auth-card {
    background: rgba(0, 0, 0, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 3rem 3.5rem;
    width: 100%;
    max-width: 420px;
    backdrop-filter: blur(12px);
  }

  h1 {
    color: #fff;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  label {
    display: block;
    color: #aaa;
    font-size: 0.85rem;
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  input {
    width: 100%;
    background: #333;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    padding: 0.85rem 1rem;
    color: #fff;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  input:focus {
    border-color: #e50914;
    background: #3a3a3a;
  }

  .auth-btn {
    width: 100%;
    background: #e50914;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 1rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    margin-top: 0.5rem;
    transition: background 0.2s, transform 0.1s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .auth-btn:hover { background: #c1121f; }
  .auth-btn:active { transform: scale(0.98); }

  .spinner {
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .auth-error {
    background: rgba(229, 9, 20, 0.15);
    border: 1px solid #e50914;
    color: #ff6b6b;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    font-size: 0.9rem;
  }

  .auth-success {
    background: rgba(40, 167, 69, 0.15);
    border: 1px solid #28a745;
    color: #5cb85c;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    font-size: 0.9rem;
  }

  .auth-footer {
    color: #aaa;
    margin-top: 1.5rem;
    text-align: center;
    font-size: 0.9rem;
  }

  .auth-footer a {
    color: #e50914;
    text-decoration: none;
    font-weight: 600;
  }

  .auth-footer a:hover { text-decoration: underline; }
</style>
